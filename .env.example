# ── ClickHouse (product telemetry) ────────────────────────────────────
# Active instances, version distribution, storage engines, deployment types, etc.
CLICKHOUSE_HOST=your-clickhouse-host.example.com
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-password-here
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=true

# Optional: query safety limits
CLICKHOUSE_QUERY_TIMEOUT=30
CLICKHOUSE_MAX_ROWS=500

# ── Elasticsearch (product downloads) ────────────────────────────────
# Downloads by product, package type, OS, growth rates, etc.
ES_HOST=your-elasticsearch-host.example.com
ES_PORT=9200
ES_USER=
ES_PASSWORD=
ES_SECURE=true
ES_VERIFY_CERTS=true

# Optional: query safety limits
ES_QUERY_TIMEOUT=30
ES_MAX_HITS=500
